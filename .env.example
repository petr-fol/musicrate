DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production

# ALLOWED_HOSTS и CSRF для Render (по умолчанию)
ALLOWED_HOSTS=localhost,127.0.0.1,*.onrender.com
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# Database - для локального запуска
# На Render используется DATABASE_URL из базы данных
DB_NAME=musicrate
DB_USER=musicrate
DB_PASSWORD=musicrate_password
DB_HOST=db
DB_PORT=5432

# Redis - для локального запуска
REDIS_URL=redis://redis:6379/0

# Yandex Music (optional - for API access)
YANDEX_MUSIC_TOKEN=

